<mxfile host="cccr"><diagram name="microservices-kafka-mq - analyse directe (reference)"><mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="450" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="order" value="&lt;b&gt;microservice-order&lt;/b&gt;&lt;br&gt;:8080&lt;br&gt;&lt;br&gt;HTTP servi (Spring MVC) :&lt;br&gt;  POST /api/order&lt;br&gt;  GET  /api/order&lt;br&gt;Spring Data REST (base /) :&lt;br&gt;  /order (CRUD) - OrderRepository&lt;br&gt;  /users (CRUD) - UserRepository&lt;br&gt;Kafka : produit 'order'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;" vertex="1" parent="1"><mxGeometry x="40" y="130" width="240" height="180" as="geometry"/></mxCell><mxCell id="topic_order" value="&lt;b&gt;Kafka topic&lt;/b&gt;&lt;br&gt;order&lt;br&gt;&lt;i&gt;pub: Order / cons: Invoice&lt;/i&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;size=15;fontSize=11;" vertex="1" parent="1"><mxGeometry x="350" y="170" width="120" height="80" as="geometry"/></mxCell><mxCell id="invoicing" value="&lt;b&gt;microservice-invoicing&lt;/b&gt;&lt;br&gt;:8081&lt;br&gt;&lt;br&gt;HTTP servi (Spring MVC) :&lt;br&gt;  ANY /&lt;br&gt;  GET /{id}&lt;br&gt;Kafka : consomme 'order'&lt;br&gt;Mongo : aucun (JPA/MySQL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontSize=11;" vertex="1" parent="1"><mxGeometry x="530" y="130" width="240" height="180" as="geometry"/></mxCell><mxCell id="e1" value="kafka · produce (Order)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSize=11;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="order" target="topic_order"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" value="kafka · consume (Invoice)" style="edgeStyle=orthogonalEdgeStyle;html=1;fontSiz